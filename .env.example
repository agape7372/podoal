# ─── Database ─────────────────────────────────────────────────
# REQUIRED. PostgreSQL only — schema.prisma's provider is `postgresql`, so a
# SQLite URL (file:./dev.db) fails immediately. Local dev uses a Docker Postgres.
# Production uses Neon (https://neon.tech).
# Get a pooled connection string from your Neon project's Connection Details page.
# NOTE the "-pooler" infix in the host — that IS the pooled (PgBouncer) endpoint.
# Without it you get the direct endpoint, which serverless lambdas exhaust quickly
# (each instance opens its own connections; src/lib/prisma.ts keeps them warm 60s).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.aws.neon.tech/neondb?sslmode=require"

# ─── Destructive DB operations (guards) ───────────────────────
# `npm run db:seed` WIPES 13 tables. src/lib/seedGuard.ts allows loopback hosts
# automatically; any other host requires BOTH of the following. Values are
# compared exactly — "True"/"1"/"yes" do NOT work, only the literal "true".
# ALLOW_DESTRUCTIVE_SEED="true"
# SEED_CONFIRM_DATABASE="<the database name in DATABASE_URL>"
#
# `npx tsx scripts/baseline-init.ts` records migrations as applied without
# running them (one-shot operator procedure — see docs/MIGRATIONS.md). It needs
# its own approval pair plus an EMPTY scratch DB to replay migrations into for
# the schema fingerprint check. The scratch DB's contents are destroyed.
# ALLOW_BASELINE="true"
# BASELINE_CONFIRM_DATABASE="<the database name in DATABASE_URL>"
# SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/scratch_db"

# ─── Auth ─────────────────────────────────────────────────────
# REQUIRED. Used to sign JWT session cookies. Min 16 characters.
# Generate with:  openssl rand -base64 32
# The app will refuse to start if this is missing or too short.
JWT_SECRET="change-me-to-a-long-random-string-at-least-16-chars"

# ─── OAuth providers ──────────────────────────────────────────
# Each provider is optional — leave blank to hide its button on the auth page.
# Redirect URI to register in each provider's console:
#   {YOUR_DEPLOYED_URL}/api/auth/oauth/{provider}/callback
# e.g. https://podoal.vercel.app/api/auth/oauth/google/callback

# Google: https://console.cloud.google.com/apis/credentials → "OAuth client ID" (Web application)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Kakao: https://developers.kakao.com → 내 애플리케이션 → 카카오 로그인 활성화 + Redirect URI
# Client Secret is optional for Kakao; leave blank if you didn't enable it.
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# Naver: https://developers.naver.com/apps → 애플리케이션 등록 → 네이버 로그인
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# Optional. Force OAuth callbacks to use this base URL (e.g. when Vercel preview
# URLs would otherwise leak into provider redirect URI registration). If unset,
# the request's origin is used.
OAUTH_REDIRECT_BASE=""

# ─── Rate limiting (shared store) ─────────────────────────────
# OPTIONAL. Without these, the rate limiter uses an in-process in-memory store
# (fine for a single instance / dev). On Vercel's many lambdas that means the
# limit is multiplied per instance — set an Upstash Redis (REST) to share one
# counter across all instances. Create a free DB at https://upstash.com →
# "REST API" → copy the URL + token. Server-only (NOT NEXT_PUBLIC); no redeploy
# code change needed — the limiter switches to Redis at runtime when both are set.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Custom grape photo (Vercel Blob) ──────────────────────────
# REQUIRED for the board-level custom image upload feature. Create a Blob store
# in the Vercel dashboard (Project → Storage → Create Database → Blob) — it
# auto-injects this var in Production/Preview once connected. For local dev,
# copy the token from the dashboard or `vercel env pull`.
BLOB_READ_WRITE_TOKEN=""

# ─── Analytics (PostHog Cloud EU) ──────────────────────────────
# OPTIONAL. Without a key the analytics wrapper (src/lib/analytics.ts) is a
# total no-op — no consent banner, no network, no bundle cost (dynamic import).
# Key: PostHog project settings (EU region — https://eu.posthog.com).
# Events fire ONLY after the user accepts the in-app consent banner.
NEXT_PUBLIC_POSTHOG_KEY=""
# Defaults to https://eu.i.posthog.com when unset.
NEXT_PUBLIC_POSTHOG_HOST=""

# ─── Web Push (VAPID) ─────────────────────────────────────────────
# OPTIONAL. Generate with tools like web-push. Both private + public keys required.
# See docs/PUSH_SETUP.md for full setup. If unset, push notifications become a no-op
# (in-app SSE messages still work).
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# Contact address for web push (defaults to mailto:noreply@podoal.app if unset).
VAPID_SUBJECT=""
# OPTIONAL. Subscription endpoints are URLs the SERVER later POSTs to, so they are
# always validated (https only, no IP literals, no private/loopback/internal hosts —
# src/lib/pushEndpoint.ts). Set to "strict" to additionally require a known browser
# push provider host (FCM / Mozilla / Windows / Apple). Strict is safer but can
# reject a legitimate provider we haven't listed, so it is opt-in.
PUSH_ENDPOINT_ALLOWLIST=""

# ─── Cron Jobs (GitHub Actions) ────────────────────────────────────
# REQUIRED for reminders/daily-nudge/weekly-recap GitHub Actions workflows.
# Generate a random secure token and set in both Vercel env + GitHub Actions secrets.
# If unset, cron endpoints return 503 (reminders, nudges, recaps don't send).
CRON_SECRET=""

# ─── App URL (OG / Share Cards) ────────────────────────────────────
# OPTIONAL. Base URL for generating Open Graph images and share cards.
# Used in layout.tsx for OG meta tags. If unset, request origin is used as fallback.
NEXT_PUBLIC_APP_URL=""

# ─── Development Tools (Production Override) ──────────────────────
# OPTIONAL. Enable dev login (/api/auth/dev) in production. Disabled by default
# in prod builds (NODE_ENV=production) unless explicitly set to "true".
ENABLE_DEV_LOGIN=""
# OPTIONAL. Enable dev-only API routes (seed-friends, dev-unlock) in production.
# If unset or false, these routes return 403/404 in prod.
NEXT_PUBLIC_DEV_TOOLS=""
