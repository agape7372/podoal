# ─── Database ─────────────────────────────────────────────────
# Local dev can use SQLite (file:./prisma/dev.db).
# Production uses PostgreSQL on Neon (https://neon.tech).
# Get a pooled connection string from your Neon project's Connection Details page.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.aws.neon.tech/neondb?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────
# REQUIRED. Used to sign JWT session cookies. Min 16 characters.
# Generate with:  openssl rand -base64 32
# The app will refuse to start if this is missing or too short.
JWT_SECRET="change-me-to-a-long-random-string-at-least-16-chars"

# ─── OAuth providers ──────────────────────────────────────────
# Each provider is optional — leave blank to hide its button on the auth page.
# Redirect URI to register in each provider's console:
#   {YOUR_DEPLOYED_URL}/api/auth/oauth/{provider}/callback
# e.g. https://podoal.vercel.app/api/auth/oauth/google/callback

# Google: https://console.cloud.google.com/apis/credentials → "OAuth client ID" (Web application)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Kakao: https://developers.kakao.com → 내 애플리케이션 → 카카오 로그인 활성화 + Redirect URI
# Client Secret is optional for Kakao; leave blank if you didn't enable it.
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# Naver: https://developers.naver.com/apps → 애플리케이션 등록 → 네이버 로그인
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# Optional. Force OAuth callbacks to use this base URL (e.g. when Vercel preview
# URLs would otherwise leak into provider redirect URI registration). If unset,
# the request's origin is used.
OAUTH_REDIRECT_BASE=""

# ─── Rate limiting (shared store) ─────────────────────────────
# OPTIONAL. Without these, the rate limiter uses an in-process in-memory store
# (fine for a single instance / dev). On Vercel's many lambdas that means the
# limit is multiplied per instance — set an Upstash Redis (REST) to share one
# counter across all instances. Create a free DB at https://upstash.com →
# "REST API" → copy the URL + token. Server-only (NOT NEXT_PUBLIC); no redeploy
# code change needed — the limiter switches to Redis at runtime when both are set.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Custom grape photo (Vercel Blob) ──────────────────────────
# REQUIRED for the board-level custom image upload feature. Create a Blob store
# in the Vercel dashboard (Project → Storage → Create Database → Blob) — it
# auto-injects this var in Production/Preview once connected. For local dev,
# copy the token from the dashboard or `vercel env pull`.
BLOB_READ_WRITE_TOKEN=""
