generator client {
  provider = "prisma-client-js"
}

// v7: 연결 URL은 schema가 아니라 prisma.config.ts(datasource.url)에서 읽는다.
datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String?  // null for OAuth-only users (Google/Kakao/Naver)
  avatar     String   @default("grape")
  provider   String?  // "google" | "kakao" | "naver" — null = email/password
  providerId String?  // user id from the OAuth provider
  createdAt  DateTime @default(now())

  // 스트릭 유예(freeze) 1회 — 계정당 한 번, 빈 어제(KST)를 메꿔 스트릭을 이어붙인다.
  streakFreezeDate   String?   // 유예로 메꾼 KST 날짜 'YYYY-MM-DD' (streak 계산 시 채워진 날로 간주)
  streakFreezeUsedAt DateTime? // 유예 소진 시각. null = 아직 보유

  // 하루 경계(FILL_CADENCE_PLAN §4) — C1은 저장만, 서버 판정은 C2부터.
  timezone     String @default("Asia/Seoul") // IANA 시간대. 클라가 접속 시 갱신 예정(C2)
  dayResetHour Int    @default(0)            // "하루의 시작" 시각(0~6) — 새벽 채움의 날짜 귀속

  // 익명 사용 통계 동의(ANALYTICS_PLAN §4) — null = 미동의/철회. 기기 간 동의 동기화용.
  analyticsConsentAt DateTime?

  boards              Board[]              @relation("BoardOwner")
  receivedBoards      Board[]              @relation("BoardReceiver")
  giftedBoards        Board[]              @relation("BoardGifter")
  sentFriendReqs      Friendship[]         @relation("FriendRequester")
  recvFriendReqs      Friendship[]         @relation("FriendReceiver")
  sentMessages        Message[]            @relation("MessageSender")
  recvMessages        Message[]            @relation("MessageReceiver")
  stickers            Sticker[]
  capsules            TimeCapsule[]
  relayCreated        Relay[]              @relation("RelayCreator")
  relayParticipations RelayParticipant[]
  notificationSetting NotificationSetting?
  reminders           Reminder[]
  pushSubscriptions   PushSubscription[]
  plantedGifts        PlantedGift[]        @relation("PlantedGiftBy")

  @@unique([provider, providerId])
}

model Board {
  id            String   @id @default(cuid())
  title         String
  description   String   @default("")
  totalStickers Int      @default(10)
  templateId    String?
  ownerId       String
  giftedToId    String?
  giftedFromId  String?
  giftMessage   String    @default("") // optional note the gifter attaches
  giftOpenedAt  DateTime? // set when the recipient first "unwraps" a gifted board
  isCompleted   Boolean  @default(false)
  allowFriendPlant Boolean @default(true) // owner toggle: may friends plant surprise gifts here?
  completedAt   DateTime?
  order         Int?      // 홈 목록 사용자 지정 정렬(null=createdAt 폴백)
  harvestedAt   DateTime? // 수확(숨김) 시각. null=노출
  cellarNote    String?   // 소믈리에 노트 — 완성 습관 회고 메모(와이너리 상세 패널, ≤200자)
  customImageUrl String? // 커스텀 알 사진(Vercel Blob URL). null=기본 보라. 소유자에게만 GET에서 노출.
  // 채움 텀(FILL_CADENCE_PLAN §2·§8, additive). FREE = 현행 무제한 — 기존 보드 무변화.
  cadenceType   String   @default("FREE") // FREE | DAILY_1 | DAILY_N | WEEKLY_N
  cadenceN      Int?      // DAILY_N(2~10) / WEEKLY_N(1~7)의 N
  strictMode    Boolean  @default(false)  // 엄격 모드(C4 옵트인) — C1은 저장만
  createdAt     DateTime @default(now())

  owner             User               @relation("BoardOwner", fields: [ownerId], references: [id])
  giftedTo          User?              @relation("BoardReceiver", fields: [giftedToId], references: [id])
  giftedFrom        User?              @relation("BoardGifter", fields: [giftedFromId], references: [id])
  stickers          Sticker[]
  rewards           Reward[]
  capsules          TimeCapsule[]
  relayParticipants RelayParticipant[]
  reminders         Reminder[]
  messages          Message[]
  plantedGifts      PlantedGift[]

  @@index([ownerId])    // 홈 보드 목록
  @@index([giftedToId]) // 받은 선물 보드·친구 활동 피드
  @@index([ownerId, isCompleted, completedAt]) // 와이너리 병 목록(완성 보드 completedAt desc) — 선두 ownerId라 홈 조회도 커버
}

model Sticker {
  id       String   @id @default(cuid())
  boardId  String
  position Int
  filledAt DateTime @default(now())
  filledBy String
  // 채움 텀 기록 플래그(FILL_CADENCE_PLAN §3·§5, additive) — 아너 시스템: 막지 않고 기록만.
  isBackfill Boolean @default(false) // 어제 몫 보충 채움(C3)
  earlyFill  Boolean @default(false) // "그래도 채우기" 소프트 오버라이드(C1)

  board  Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  filler User  @relation(fields: [filledBy], references: [id])

  @@unique([boardId, position])
  // 복합 인덱스(filledBy, filledAt): stats·winery·vine의 사용자별 집계가 날짜순으로
  // 인덱스만 훑어 끝낸다(헤비유저 전체 이력 풀스캔 제거). 선두 컬럼이 filledBy라
  // 기존 filledBy 단독 조회도 그대로 커버.
  @@index([filledBy, filledAt])
}

model Reward {
  id          String    @id @default(cuid())
  boardId     String
  type        String    // "letter" | "giftcard" | "wish"
  title       String
  content     String
  imageUrl    String    @default("")
  triggerAt   Int       // sticker count to trigger this reward (e.g. 3, 5, 10)
  unlockedAt  DateTime? // set when the sticker count first reaches triggerAt (single-shot guard)
  revealedAt  DateTime? // set when the user opens the reward to see its contents

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, triggerAt])
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  receiverId  String
  status      String   @default("pending") // "pending" | "accepted"
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())

  requester User @relation("FriendRequester", fields: [requesterId], references: [id])
  receiver  User @relation("FriendReceiver", fields: [receiverId], references: [id])

  @@unique([requesterId, receiverId])
  // (receiverId, status): 받은 친구신청 + pending 필터를 한 인덱스로 — receiverId
  // 파티션 내에서 status='pending'으로 바로 점프(2차 필터 제거). 선두가 receiverId라
  // 기존 receiverId 단독 조회도 커버.
  @@index([receiverId, status])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  boardId    String?
  content    String
  type       String   @default("cheer") // "cheer" | "celebration" | "gift"
  emoji      String   @default("🍇")
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User   @relation("MessageSender", fields: [senderId], references: [id])
  receiver User   @relation("MessageReceiver", fields: [receiverId], references: [id])
  board    Board? @relation(fields: [boardId], references: [id], onDelete: SetNull)

  // SSE가 접속 클라이언트당 10초마다 (receiverId, createdAt>) 조회 — 최다 빈도 쿼리.
  // 복합 인덱스라 receiverId 단독 조회(인박스)도 접두로 커버한다.
  @@index([receiverId, createdAt])
  // 보드 삭제·계정 탈퇴 캐스케이드(onDelete: SetNull)가 boardId로 대상 행을 찾는다 — 풀스캔 방지.
  @@index([boardId])
}

model TimeCapsule {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  message   String
  emoji     String   @default("🍇")
  openAt    DateTime
  isOpened  Boolean  @default(false)
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  // capsules 라우트가 boardId로, vine(90일)·export가 (userId, openAt)로 조회 — 둘 다 풀스캔이었다.
  @@index([boardId])
  @@index([userId, openAt])
}

model Relay {
  id            String   @id @default(cuid())
  title         String
  templateId    String?
  totalStickers Int      @default(10)
  creatorId     String
  status        String   @default("active") // active | completed
  mode          String   @default("relay")  // relay(순차) | group(병렬)
  createdAt     DateTime @default(now())

  creator      User               @relation("RelayCreator", fields: [creatorId], references: [id])
  participants RelayParticipant[]

  // relays GET의 OR 좌항(creatorId = 나) — participants 측은 RelayParticipant [userId]가 커버.
  @@index([creatorId])
}

model RelayParticipant {
  id       String   @id @default(cuid())
  relayId  String
  userId   String
  boardId  String?
  order    Int
  status   String   @default("pending") // pending(순차 대기) | invited(그룹 초대) | active | completed — 'invited'는 relays 라우트 실사용
  joinedAt DateTime @default(now())

  relay Relay  @relation(fields: [relayId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [userId], references: [id])
  board Board? @relation(fields: [boardId], references: [id])

  @@unique([relayId, userId])
  @@unique([relayId, order])
  @@index([userId]) // 내 포도동/초대 조회 (unique 2개 모두 relayId 접두라 커버 안 됨)
  // boards/[id] GET의 포도동 동료 열람 권한 체크가 boardId로 조회 — 인덱스 없으면
  // 테이블 풀스캔(친구 아닌 릴레이 참가자의 보드 진입마다). 보드 상세는 최빈 전환.
  @@index([boardId])
}

model NotificationSetting {
  id              String  @id @default(cuid())
  userId          String  @unique
  globalEnabled   Boolean @default(true)
  dndStart        String  @default("22:00")
  dndEnd          String  @default("08:00")
  cheerEnabled    Boolean @default(true)
  rewardEnabled   Boolean @default(true)
  relayEnabled    Boolean @default(true)
  reminderEnabled Boolean @default(true)
  // 데일리 넛지 opt-in — 기본 꺼짐(ADHD 가드레일: 알림은 적게). 기존 행에도 false 적용.
  dailyNudgeEnabled Boolean   @default(false)
  // 데일리 넛지 일일 중복발송 가드(KST 날짜 비교) — Reminder.lastSentAt 패턴 재사용
  lastNudgeSentAt   DateTime?
  // 주간 결산 푸시 전용 opt-in — 기본 켜짐(기존 reminder 편승 수신자 행동 무변화, 사용자 결정 2026-07-11)
  weeklyRecapEnabled Boolean @default(true)

  user User @relation(fields: [userId], references: [id])
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  boardId   String?
  // "time"(시각 지정) | "ripe"(익으면 알림 — cadence 보드 전용, boardId 필수). 미인식 값은 cron이 "time" 취급(fail-open)
  type      String   @default("time")
  time      String
  days      String   @default("1,2,3,4,5,6,7")
  message   String   @default("")
  isActive  Boolean  @default(true)
  lastSentAt DateTime? // server-side cron dedupe: last time a push fired for this reminder
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  board Board? @relation(fields: [boardId], references: [id])

  // cron/reminders가 5분마다 (isActive, time<=now) 형상으로 조회 — 풀스캔 방지.
  // userId는 리마인더 목록·export 조회용.
  @@index([isActive, time])
  @@index([userId])
}

// Web Push (VAPID) subscription endpoints. One row per browser/device per user.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A surprise gift a FRIEND hides on a specific grape of someone's board.
// Revealed (with confetti) the moment the owner fills that grape.
model PlantedGift {
  id          String    @id @default(cuid())
  boardId     String
  position    Int       // 0-based grape index the surprise hides on
  plantedById String
  message     String    @default("")
  emoji       String    @default("🎁")
  revealedAt  DateTime?
  createdAt   DateTime  @default(now())

  board     Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  plantedBy User  @relation("PlantedGiftBy", fields: [plantedById], references: [id])

  @@index([boardId])
}
