{
  "name": "podoal",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.13.0",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/migrate-deploy.mjs && next build",
    "start": "next start",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"src/**/*.test.ts\"",
    "test:integration": "node --import tsx --test \"tests/integration/**/*.test.ts\"",
    "lint": "eslint . && node scripts/check-icons.mjs",
    "check:icons": "node scripts/check-icons.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@vercel/blob": "^2.6.1",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "next": "^16.2.10",
    "posthog-js": "^1.404.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "web-push": "^3.6.7",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.2.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.20",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
